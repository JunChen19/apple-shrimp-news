# Tavily API Key (必填)
TAVILY_API_KEY=tvly-your-api-key-here

# 后端配置
DATABASE_URL=sqlite+aiosqlite:///./backend/data/articles.db
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=7
SCHEDULER_MINUTE=0

# GitHub Pages 部署（可选）
GITHUB_TOKEN=
GITHUB_REPO=apple-shrimp-news
GITHUB_BRANCH=gh-pages

# 前端配置
NEXT_PUBLIC_API_URL=http://localhost:8000
