# Tavily API Key (required)
TAVILY_API_KEY=tvly-your-api-key-here

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/articles.db

# Server
HOST=0.0.0.0
PORT=8000

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=7
SCHEDULER_MINUTE=0

# GitHub Pages (optional, for auto-deploy)
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=gh-pages
